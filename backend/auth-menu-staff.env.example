# ===========================================
# Auth/Menu/Staff docker stack (server)
# Copy this file to ".env.auth-menu-staff"
# ===========================================

# Public gateway port exposed by nginx container
GATEWAY_HOST_PORT=5555

# Optional frontend upstream for "/" proxy.
# If frontend is not running on this host, keep default.
FRONTEND_UPSTREAM=host.docker.internal:3001

# Oracle datasource (external DB)
SPRING_DATASOURCE_URL=jdbc:log4jdbc:oracle:thin:@//192.168.1.67:1521/XE
SPRING_DATASOURCE_USERNAME=hospital
SPRING_DATASOURCE_PASSWORD=1111

# Redis password used by in-stack redis and backend
SPRING_REDIS_PASSWORD=111111

# Security secrets (MUST change for non-local usage)
APP_JWT_SECRET=change-this-to-a-long-random-secret
APP_AUTH_INTROSPECTION_SECRET=change-this-to-another-long-random-secret

# Auth/session options
APP_JWT_EXPIRATION_MS=28800000
APP_AUTH_COOKIE_MAX_AGE_SECONDS=28800
APP_AUTH_SESSION_IDLE_SECONDS=7200
APP_AUTH_SESSION_ABSOLUTE_SECONDS=43200

# Verification/cors (dev-friendly defaults)
APP_VERIFY_EMAIL_MOCK=true
APP_VERIFY_SMS_MOCK=true
APP_CORS_ALLOWED_ORIGIN_PATTERNS=*
